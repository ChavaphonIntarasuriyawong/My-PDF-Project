rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Authenticated users can read/write their own PDFs
    match /pdfs/{uid}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Authenticated users can read/write their own avatar
    match /avatars/{uid}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
