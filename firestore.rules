rules_version = '2';

// MyPDF Firestore security rules.
// Schema: users, bookshelves, books, notes (see CLAUDE.md).
// Dates are ISO 8601 strings in app code, but server-write timestamps
// (createdAt / updatedAt / lastReadAt) are validated as `timestamp` here
// when written via FieldValue.serverTimestamp() — string writes are
// rejected by timestampValid(). RBAC: 'admin' role gets read-only access
// to all books for a mock dashboard. No public reads anywhere.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function changedFields() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Per CLAUDE.md the app writes ISO 8601 strings (not Firestore Timestamp).
    // Accept both: native timestamp (with grace window) OR a non-empty ISO string.
    // Server-time abuse is bounded by Firestore enforcing client-clock skew elsewhere;
    // this gate is mostly a type+presence check for the schema audit.
    function timestampValid(field) {
      return field in request.resource.data && (
        (request.resource.data[field] is timestamp &&
          request.resource.data[field] <= request.time + duration.value(5, 'm'))
        ||
        (request.resource.data[field] is string &&
          request.resource.data[field].size() > 0)
      );
    }

    function bookOwner(bookId) {
      return get(/databases/$(database)/documents/books/$(bookId)).data.ownerId;
    }

    // ---------- users/{uid} ----------
    // Profile doc. Owner-only read/write. Role is immutable from client
    // (server / admin SDK only); 'user' is the sole allowed value at create.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(['name', 'email', 'role', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.role == 'user'
        && timestampValid('createdAt');

      // Only name / email mutable. role + createdAt + email-uid binding stays put.
      allow update: if isOwner(uid)
        && changedFields().hasOnly(['name', 'email']);

      allow delete: if false;
    }

    // ---------- bookshelves/{shelfId} ----------
    match /bookshelves/{shelfId} {
      allow read: if isSignedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.keys().hasOnly(['name', 'ownerId', 'createdAt'])
        && request.resource.data.name is string
        && timestampValid('createdAt');

      // Only `name` is mutable. ownerId + createdAt are locked.
      allow update: if isOwner(resource.data.ownerId)
        && changedFields().hasOnly(['name'])
        && request.resource.data.name is string;

      allow delete: if isOwner(resource.data.ownerId);
    }

    // ---------- books/{bookId} ----------
    // Owner read+write. Admins get read-only across all owners.
    // Mutable: title, currentPage, progress, status, lastReadAt, shelfId,
    //          isLocked, lockHash.
    // Immutable: ownerId, link, totalPages, needsOcr, author, year.
    // Note: lockHash is a salted SHA-256-crypt string written by the client.
    // Even if abused, the raw PIN cannot be recovered without offline brute
    // force — format check is intentionally client-side.
    match /books/{bookId} {
      allow read: if isSignedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.link is string
        && request.resource.data.totalPages is int
        && request.resource.data.currentPage is int
        && request.resource.data.status in ['reading', 'on_hold', 'finished']
        && (!('lastReadAt' in request.resource.data) || timestampValid('lastReadAt'));

      allow update: if isOwner(resource.data.ownerId)
        && changedFields().hasOnly([
          'title', 'currentPage', 'progress', 'status', 'lastReadAt', 'shelfId',
          'isLocked', 'lockHash'
        ])
        && (!('lastReadAt' in changedFields()) || timestampValid('lastReadAt'))
        && (!('status' in changedFields())
            || request.resource.data.status in ['reading', 'on_hold', 'finished']);

      allow delete: if isOwner(resource.data.ownerId);
    }

    // ---------- notes/{noteId} ----------
    // Note ownership resolves through the parent book's ownerId.
    // Mutable: title, content, updatedAt. Immutable: bookId, createdAt.
    match /notes/{noteId} {
      allow read: if isSignedIn()
        && (bookOwner(resource.data.bookId) == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
        && bookOwner(request.resource.data.bookId) == request.auth.uid
        && request.resource.data.keys().hasOnly(['bookId', 'title', 'content', 'createdAt', 'updatedAt'])
        && request.resource.data.title is string
        && request.resource.data.content is string
        && timestampValid('createdAt')
        && timestampValid('updatedAt');

      allow update: if isSignedIn()
        && bookOwner(resource.data.bookId) == request.auth.uid
        && changedFields().hasOnly(['title', 'content', 'updatedAt'])
        && timestampValid('updatedAt');

      allow delete: if isSignedIn()
        && bookOwner(resource.data.bookId) == request.auth.uid;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
